generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Flavor {
  code      String   @id @db.Text
  name      String   @unique @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lots      Lot[]

  @@map("flavors")
}

model Operator {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.Text
  active    Boolean  @default(true)
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  version   Int      @default(1)
  lots      Lot[]

  @@map("operators")
}

model Lot {
  id               BigInt         @id @default(autoincrement())
  lotNumber        String         @unique @map("lot_number") @db.Text
  productionDate   DateTime       @map("production_date") @db.Date
  productionPeriod String         @map("production_period") @db.Text
  flavorCode       String         @map("flavor_code") @db.Text
  sizeMl           Int            @map("size_ml") @db.SmallInt
  batchNo          Int            @map("batch_no") @db.SmallInt
  quantity         Int
  bestBefore       DateTime       @map("best_before") @db.Date
  operatorId       BigInt         @map("operator_id")
  operatorName     String         @map("operator_name") @db.Text
  note             String?        @db.Text
  status           String         @default("active") @db.Text
  createdBy        String         @map("created_by") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  voidReason       String?        @map("void_reason") @db.Text
  voidedBy         String?        @map("voided_by") @db.Uuid
  voidedAt         DateTime?      @map("voided_at") @db.Timestamptz(6)
  version          Int            @default(1)
  flavor           Flavor         @relation(fields: [flavorCode], references: [code])
  operator         Operator       @relation(fields: [operatorId], references: [id])
  events           LotEvent[]
  shipmentItems    ShipmentItem[]

  @@index([productionDate])
  @@index([status, productionDate])
  @@index([flavorCode, sizeMl, productionDate, status])
  @@index([operatorId])
  @@map("lots")
}

model LotEvent {
  id          BigInt   @id @default(autoincrement())
  lotId       BigInt   @map("lot_id")
  eventType   String   @map("event_type") @db.Text
  reason      String?  @db.Text
  actorUserId String?  @map("actor_user_id") @db.Uuid
  snapshot    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lot         Lot      @relation(fields: [lotId], references: [id])

  @@index([lotId, createdAt(sort: Desc)])
  @@map("lot_events")
}

model Partner {
  id              BigInt         @id @default(autoincrement())
  name            String         @db.Text
  billingName     String?        @map("billing_name") @db.Text
  taxNumber       String?        @map("tax_number") @db.Text
  shippingAddress String?        @map("shipping_address") @db.Text
  contactName     String?        @map("contact_name") @db.Text
  email           String?        @db.Text
  phone           String?        @db.Text
  note            String?        @db.Text
  active          Boolean        @default(true)
  createdBy       String         @map("created_by") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  version         Int            @default(1)
  shipments       Shipment[]
  users           AppUser[]

  @@index([active, name])
  @@map("partners")
}

model Shipment {
  id                  BigInt          @id @default(autoincrement())
  shipmentNumber      String          @unique @map("shipment_number") @db.Text
  shipmentYear        Int             @map("shipment_year") @db.SmallInt
  shipmentSequence    Int             @map("shipment_sequence")
  partnerId           BigInt          @map("partner_id")
  shipmentDate        DateTime        @map("shipment_date") @db.Date
  shippingAddress     String?         @map("shipping_address") @db.Text
  customerOrderNumber String?         @map("customer_order_number") @db.Text
  deliveryNoteNumber  String?         @map("delivery_note_number") @db.Text
  note                String?         @db.Text
  status              String          @default("draft") @db.Text
  createdBy           String          @map("created_by") @db.Uuid
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  closedBy            String?         @map("closed_by") @db.Uuid
  closedAt            DateTime?       @map("closed_at") @db.Timestamptz(6)
  shippedBy           String?         @map("shipped_by") @db.Uuid
  shippedAt           DateTime?       @map("shipped_at") @db.Timestamptz(6)
  voidedBy            String?         @map("voided_by") @db.Uuid
  voidedAt            DateTime?       @map("voided_at") @db.Timestamptz(6)
  voidReason          String?         @map("void_reason") @db.Text
  version             Int             @default(1)
  partner             Partner         @relation(fields: [partnerId], references: [id])
  items               ShipmentItem[]
  events              ShipmentEvent[]

  @@unique([shipmentYear, shipmentSequence])
  @@index([partnerId, shipmentDate(sort: Desc)])
  @@index([status, shipmentDate(sort: Desc)])
  @@map("shipments")
}

model ShipmentItem {
  id         BigInt   @id @default(autoincrement())
  shipmentId BigInt   @map("shipment_id")
  lotId      BigInt   @map("lot_id")
  quantity   Int
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  version    Int      @default(1)
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  lot        Lot      @relation(fields: [lotId], references: [id])

  @@unique([shipmentId, lotId])
  @@index([lotId])
  @@index([shipmentId])
  @@map("shipment_items")
}

model ShipmentEvent {
  id          BigInt   @id @default(autoincrement())
  shipmentId  BigInt   @map("shipment_id")
  eventType   String   @map("event_type") @db.Text
  reason      String?  @db.Text
  actorUserId String?  @map("actor_user_id") @db.Uuid
  snapshot    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt(sort: Desc)])
  @@map("shipment_events")
}

model AppUser {
  userId      String   @id @map("user_id") @db.Uuid
  email       String?  @db.Text
  displayName String?  @map("display_name") @db.Text
  role        String   @default("staff") @db.Text
  partnerId   BigInt?  @map("partner_id")
  active      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  partner     Partner? @relation(fields: [partnerId], references: [id])

  @@index([role, active])
  @@map("app_users")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.Text
  entityType  String   @map("entity_type") @db.Text
  entityId    String?  @map("entity_id") @db.Text
  beforeData  Json?    @map("before_data")
  afterData   Json?    @map("after_data")
  requestId   String?  @map("request_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@map("audit_log")
}

model IdempotencyKey {
  key          String   @id @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  route        String   @db.Text
  requestHash  String   @map("request_hash") @db.Text
  responseCode Int?     @map("response_code")
  responseBody Json?    @map("response_body")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)

  @@index([userId, route])
  @@index([expiresAt])
  @@map("idempotency_keys")
}
